    "lenis": "^1.3.17",
    "lucide-react": "^0.395.0",
    "mongoose": "^9.6.2",
    "next": "14.2.4",
    "next-auth": "^4.24.14",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.3.0",
    "zod": "^4.4.3"
