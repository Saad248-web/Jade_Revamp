{
  "name": "jade-revamp",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate_media_manifest.mjs",
    "generate-favicons": "node scripts/generate_favicons.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npm run build && cross-env CI=true playwright test",
    "optimize-images": "node scripts/optimize_public_images.mjs",
    "optimize-images:dry-run": "node scripts/optimize_public_images.mjs --dry-run",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:reset": "docker compose -f docker-compose.db.yml down -v && docker compose -f docker-compose.db.yml up -d",
    "db:reset:schema": "node scripts/reset-local-db.mjs",
    "db:migrate": "node scripts/run-db-migrations.mjs",
    "db:seed": "node scripts/seed-villas.mjs",
    "db:seed:users": "node scripts/seed-users.mjs",
    "db:test": "node scripts/test-mongo.mjs",
    "api:smoke": "node scripts/smoke-api-live.mjs",
    "setup:check": "node scripts/verify-local-setup.mjs",
    "setup:guide": "node scripts/open-setup-guide.mjs"
  },
