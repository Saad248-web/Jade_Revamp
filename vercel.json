{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/expire-pending-bookings",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/axisrooms-retry",
      "schedule": "*/15 * * * *"
    }
  ]
}
