# Jade Hospitainment — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Hero videos (CDN) ────────────────────────────────────
NEXT_PUBLIC_CDN_BASE=https://jadehospitainment.com/videos

# ─── API ──────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.jadehospitainment.com
NEXT_PUBLIC_SITE_URL=https://jadehospitainment.com

# ─── MongoDB (single database — bookings, leads, CMS, users) ─
# Tier 1: Atlas free tier replica set or local Docker with rs.initiate()
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/jade?retryWrites=true&w=majority

# ─── Payment Gateway (Razorpay) ───────────────────────────
NEXT_PUBLIC_PAYMENT_GATEWAY_KEY=your_razorpay_test_key_id
RAZORPAY_KEY_ID=your_razorpay_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Auth & cron ──────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=your_long_random_cron_secret

# ─── Axis Rooms channel manager (sandbox from Axis email 2026-07-01) ─
# PMS name to register with Axis: Jade Host PMS
AXIS_ROOMS_PMS_NAME=Jade Host PMS
AXIS_ROOMS_API_BASE_URL=https://sandbox2.axisrooms.com
AXIS_ROOMS_CHANNEL_ID=227
AXIS_ROOMS_API_KEY=
# Legacy — API 9 validates accessKey in JSON body, not Bearer header
AXIS_ROOMS_WEBHOOK_SECRET=

# ─── Transactional email (Resend, optional) ───────────────
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Jade Hospitainment <bookings@yourdomain.com>
LEADS_NOTIFY_EMAIL=concierge@yourdomain.com,ops@yourdomain.com
CAREERS_NOTIFY_EMAIL=careers@yourdomain.com,hr@yourdomain.com
BOOKING_NOTIFY_EMAIL=bookings@yourdomain.com,ops@yourdomain.com
CONFLICT_NOTIFY_EMAIL=bookings@yourdomain.com,ops@yourdomain.com
# Set BOOKING_GUEST_CONFIRM_EMAIL=false to skip guest confirmation emails

# ─── Observability (optional) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── Analytics ────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Seed users (npm run db:seed:users) ─────────────────────
# Default password for all seeded accounts if unset: JadeHost2026!
# Rotate before production — see NEEDS_FROM_USER.md
# SEED_USER_PASSWORD=

# ─── IndexNow (required in production) ────────────────────
INDEXNOW_KEY=
INDEXNOW_HOST=jadehospitainment.com
INDEXNOW_API_SECRET=your_long_random_indexnow_hook_secret_here

# ─── Optional degraded read-only fallback when Mongo unreachable ─
# BOOKINGS_STORE_FALLBACK=true
