# Jade Hospitainment — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── API ──────────────────────────────────────────────────
# Base URL for the backend API (used in lib/api.ts when switching from mock data)
NEXT_PUBLIC_API_BASE_URL=https://api.jadehospitainment.com

# ─── Payment Gateway ─────────────────────────────────────
# Your payment provider public key (Razorpay, Stripe, etc.)
# Used in lib/paymentService.ts → initiatePayment()
NEXT_PUBLIC_PAYMENT_GATEWAY_KEY=your_razorpay_key_id_here
# Server secrets for POST /api/payments/razorpay-order — must match Razorpay dashboard
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Webhook signing secret from Razorpay Dashboard → Webhooks → your endpoint (POST /api/webhooks/razorpay)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ─── Transactional email (Resend, optional) ─────────────────
# Omit RESEND_API_KEY to skip sending — enquiries/applications/bookings still save to Postgres.
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Jade Hospitainment <bookings@yourdomain.com>
LEADS_NOTIFY_EMAIL=concierge@yourdomain.com
CAREERS_NOTIFY_EMAIL=careers@yourdomain.com
BOOKING_NOTIFY_EMAIL=bookings@yourdomain.com
# BOOKING_GUEST_CONFIRM_EMAIL=false  # uncomment to suppress guest copy

# ─── Observability (optional) ────────────────────────────────
# Sentry — leave unset locally to disable; set DSN in production.
# Create a Browser + Node project at https://sentry.io and paste the DSN.
NEXT_PUBLIC_SENTRY_DSN=
# Optional separate server DSN (defaults to NEXT_PUBLIC_SENTRY_DSN)
# SENTRY_DSN=
# CI source maps (optional): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
# Next.js 14: suppress SDK warning about onRequestError (Next 15+ feature)
# SENTRY_SUPPRESS_INSTRUMENTATION_FILE_WARNING=1

# ─── E2E (Playwright) ───────────────────────────────────────
# Local: `npm run test:e2e` (starts next dev). Stable/CI: `npm run test:e2e:ci` (build + next start).
# Optional: PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# ─── Analytics ─────────────────────────────────────────────
# Loaded by src/components/analytics/GoogleAnalytics.tsx (SPA page views)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Enquiry & careers (demo vs live — Phase 2) ─────────────
# Default: demo ON (no Postgres). Enquire, Footer, and Partner overlay skip API when true.
# Set false when DB is up (npm run db:up, db:migrate).
# NEXT_PUBLIC_ENQUIRY_DEMO_MODE=false
# NEXT_PUBLIC_CAREERS_DEMO_MODE=false

# ─── Database (PostgreSQL) ───────────────────────────
# Used in src/lib/db.ts for booking storage
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jadehost
POSTGRES_USER=jadeuser
POSTGRES_PASSWORD=your_password_here

# ─── Admin ───────────────────────────────────────
# Strong secret for booking admin APIs (GET list, PATCH, DELETE via x-admin-password header)
ADMIN_PASSWORD=your_long_random_admin_secret_here

# ─── IndexNow (optional) ──────────────────────────
# Used in src/app/api/indexnow/route.ts
INDEXNOW_KEY=a8f9c1b2d4e64f789012345678abcdef
INDEXNOW_HOST=jadehospitainment.com
# Required in production: POST requests must send Authorization: Bearer <secret>
INDEXNOW_API_SECRET=your_long_random_indexnow_hook_secret_here
