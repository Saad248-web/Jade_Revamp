# Jade Hospitainment — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── API ──────────────────────────────────────────────────
# Base URL for the backend API (used in lib/api.ts when switching from mock data)
NEXT_PUBLIC_API_BASE_URL=https://api.jadehospitainment.com

# ─── Payment Gateway ─────────────────────────────────────
# Your payment provider public key (Razorpay, Stripe, etc.)
# Used in lib/paymentService.ts → initiatePayment()
NEXT_PUBLIC_PAYMENT_GATEWAY_KEY=your_razorpay_key_id_here

# ─── Analytics (optional) ────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
6: 
7: # ─── Database (PostgreSQL) ───────────────────────────
8: # Used in src/lib/db.ts for booking storage
9: POSTGRES_HOST=localhost
10: POSTGRES_PORT=5432
11: POSTGRES_DB=jadehost
12: POSTGRES_USER=jadeuser
13: POSTGRES_PASSWORD=your_password_here
14: 
15: # ─── Admin ───────────────────────────────────────
16: # Password for GET /api/bookings auth (x-admin-password)
17: ADMIN_PASSWORD=your_admin_secret_here
