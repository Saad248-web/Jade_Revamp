# Jade Hospitainment — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Hero videos (CDN) ────────────────────────────────────
NEXT_PUBLIC_CDN_BASE=https://jadehospitainment.com/videos

# ─── API ──────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.jadehospitainment.com
# Public site origin for SEO / dashboard absolute links (never use localhost on deployed envs)
NEXT_PUBLIC_SITE_URL=https://jade-revamp.vercel.app
# Optional server-only override for dashboard deep-links in staff emails
# SITE_URL=https://jade-revamp.vercel.app
# Guest-facing email footer (Privacy / Terms / Refund) — should match Resend sending domain
EMAIL_SITE_URL=https://jaderetreats.com

# ─── MongoDB (single database — bookings, leads, CMS, users) ─
# App reads ONLY MONGODB_URI — one variable per environment:
#   Local:  127.0.0.1 (npm run db:start)  |  Vercel/VPS remote: your server public IP
# Local self-hosted example (start: npm run db:start):
# MONGODB_URI=mongodb://jadeapp_user:Stack%402026@127.0.0.1:27017/jadeapp?authSource=jadeapp
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/jade?retryWrites=true&w=majority

# ─── Payment Gateway (Razorpay) ───────────────────────────
# Mode: test | razorpay_test | production
#   test          — simulated Pay (local UAT, no Razorpay keys; blocked on Vercel production)
#   razorpay_test — Razorpay sandbox test keys below
#   production    — live Razorpay keys at go-live (see NEEDS_FROM_USER.md)
PAYMENT_GATEWAY_MODE=test
NEXT_PUBLIC_PAYMENT_GATEWAY_MODE=test
NEXT_PUBLIC_PAYMENT_GATEWAY_KEY=your_razorpay_test_key_id
RAZORPAY_KEY_ID=your_razorpay_test_key_id
RAZORPAY_KEY_SECRET=your_razorpay_test_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Auth & cron ──────────────────────────────────────────
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=your_long_random_cron_secret

# ─── Axis Rooms channel manager (sandbox from Axis email 2026-07-01) ─
# PMS name to register with Axis: Jade Host PMS
AXIS_ROOMS_PMS_NAME=Jade Host PMS
AXIS_ROOMS_API_BASE_URL=https://sandbox2.axisrooms.com
AXIS_ROOMS_CHANNEL_ID=227
AXIS_ROOMS_API_KEY=227As8u5RA3v1CH8o6uBE6YdhassenaVayyy
# Optional — defaults used by npm run axis:test if unset
AXIS_TEST_HOTEL_ID=1303
AXIS_TEST_ROOM_ID=1
AXIS_TEST_RATE_PLAN_ID=1
# API 9 inbound: register https://<your-domain>/api/webhooks/axisrooms with Axis
# Validates Rates.roomType id/ratePlanId against villa mapping; rejects invalid payloads (422)
# API 5 verify on inbound API 9 (set false only if sandbox key not yet active)
AXIS_ROOMS_INBOUND_VERIFY_AXIS=true
# AXIS_ROOMS_INBOUND_LOG_FILE=false     # skip local logs/axisrooms-inbound.jsonl
# AXIS_ROOMS_WEBHOOK_SECRET=  # legacy; API 9 uses accessKey in JSON body

# ─── Transactional email (Resend) ───────────────────────────
# Rotate API keys in Resend dashboard if ever exposed — store only in .env.local / Vercel
RESEND_API_KEY=re_xxxxxxxx
# Sender (FROM) — verified domain address on Resend
RESEND_FROM=Jade Retreats <bookings@jaderetreats.com>

# Staff inbox (TO) — ALL staff alerts go here only; do not use split notify vars
STAFF_NOTIFY_EMAIL=Enquiry@jaderetreats.com

# Guest booking confirmations go to the guest email captured on the form
# Set BOOKING_GUEST_CONFIRM_EMAIL=false to skip guest confirmation emails

# Deprecated — optional fallbacks during migration only (remove after cutover):
# BOOKING_NOTIFY_EMAIL=bookings@yourdomain.com
# LEADS_NOTIFY_EMAIL=concierge@yourdomain.com
# CAREERS_NOTIFY_EMAIL=careers@yourdomain.com
# PARTNER_NOTIFY_EMAIL=partners@yourdomain.com
# CONFLICT_NOTIFY_EMAIL=bookings@yourdomain.com

# ─── Observability (optional) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── Analytics ────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Seed users (npm run db:seed:users) ─────────────────────
# Default password for all seeded accounts if unset: JadeHost2026!
# Rotate before production — see NEEDS_FROM_USER.md
# SEED_USER_PASSWORD=

# ─── IndexNow (required in production) ────────────────────
INDEXNOW_KEY=
INDEXNOW_HOST=jadehospitainment.com
INDEXNOW_API_SECRET=your_long_random_indexnow_hook_secret_here

# ─── Optional degraded read-only fallback when Mongo unreachable ─
# BOOKINGS_STORE_FALLBACK=true
